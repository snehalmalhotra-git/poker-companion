import { useState } from "react";

function App() {

const [playerCount, setPlayerCount] = useState(6);
const [players, setPlayers] = useState([]);
const [currentPlayer, setCurrentPlayer] = useState(0);
const [winner, setWinner] = useState(null);
const [pot, setPot] = useState(30);
const [currentBet, setCurrentBet] = useState(20);
const [raiseAmount,  setRaiseAmount] = useState(20);
const [street, setStreet] = useState("PREFLOP");
const [actionLog, setActionLog] = useState([]);
const [lastRaiser, setLastRaiser] = useState(null);
const [actionCount, setActionCount] = useState(0);
const [selectedWinner, setSelectedWinner] = useState(null);
const [handComplete, setHandComplete] = useState(false);
const [gameStarted, setGameStarted] = useState(false);
const [playerNames, setPlayerNames] =
  useState([
    "Player 1",
    "Player 2",
    "Player 3",
    "Player 4",
    "Player 5",
    "Player 6",
    "Player 7",
    "Player 8",
    "Player 9",
    "Player 10",
  ]);

const [boardCards, setBoardCards] = useState(0);
const buttonStyle = {
  padding: "12px 20px",
  fontSize: "18px",
  borderRadius: "12px",
  border: "none",
  cursor: "pointer",
};
const playClick = () => {
  new Audio("/click.mp3").play();
};

function nextPlayer() {
  let next = (currentPlayer + 1) % players.length;

  while (players[next].folded) {
    next = (next + 1) % players.length;
  }

  setCurrentPlayer(next);
}

function foldPlayer() {
  playClick();
  const updatedPlayers = [...players];

  const player = updatedPlayers[currentPlayer];

  if (street === "SHOWDOWN") {
    return;
  }

  player.folded = true;

  setPlayers(updatedPlayers);

  addAction(
    `${player.name} folds`
  );

  const remaining = updatedPlayers.filter(
    (player) => !player.folded
  );
  
  if (remaining.length === 1) {

    const winnerIndex =
      updatedPlayers.findIndex(
        p => p.name === remaining[0].name
      );
  
    updatedPlayers[winnerIndex].chips += pot;
  
    setPlayers(updatedPlayers);
  
    setPot(0);
  
    setWinner(remaining[0].name);

    setHandComplete(true);
  
    return;
  }

  setActionCount(prev => prev + 1);
  nextPlayer();
}

function activePlayers() {
  return players.filter(
    (player) => !player.folded
  ).length;
}

function checkAction() {
  playClick();

  const player = players[currentPlayer];

  if (street === "SHOWDOWN") {
    return;
  }

  if (player.bet !== currentBet) {
    return;
  }

  addAction(
    `${player.name} checks`
  );

  setActionCount(prev => prev + 1);
  if (bettingRoundComplete(players)) {
    advanceStreet();
  } else {
    nextPlayer();
  }
}

function callAction() {
  playClick();
  const updatedPlayers = [...players];

  const player = updatedPlayers[currentPlayer];

  const diff = currentBet - player.bet;

  if (street === "SHOWDOWN") {
    return;
  }

  if (diff > player.chips) {
    return;
  }

  player.chips -= diff;
  player.bet += diff;

  setPlayers(updatedPlayers);

  setPot(pot + diff);

  addAction(
    `${player.name} calls`
  );

  setActionCount(prev => prev + 1);
  if (bettingRoundComplete(updatedPlayers)) {
    advanceStreet();
  } else {nextPlayer();}
}

function raiseAction() {
  playClick();
  const updatedPlayers = [...players];

  const player = updatedPlayers[currentPlayer];

  const newBet = currentBet + raiseAmount;

  const diff = newBet - player.bet;

  if (street === "SHOWDOWN") {
    return;
  }

  if (diff > player.chips) {
    return;
  }

  player.chips -= diff;
  player.bet += diff;

  setPlayers(updatedPlayers);

  setPot(pot + diff);

  setCurrentBet(newBet);

  setLastRaiser(currentPlayer);

  addAction(
    `${player.name} raises to ${newBet}`
  );
 
  setActionCount(prev => prev + 1);
  nextPlayer();
}

function bettingRoundComplete(playersToCheck) {

  const allMatched = playersToCheck.every(
    (player) =>
      player.folded ||
      player.bet === currentBet
  );

  let next =
    (currentPlayer + 1) %
    playersToCheck.length;

  while (
    playersToCheck[next].folded
  ) {
    next =
      (next + 1) %
      playersToCheck.length;
  }

  console.log("lastRaiser =", lastRaiser);
  console.log("allMatched =", allMatched);
  console.log("next =", next);
  console.log("ACTION COUNT", actionCount);

  if (lastRaiser === null) {

    const activePlayerCount =
      playersToCheck.filter(
        p => !p.folded
      ).length;
  
      return (actionCount + 1) >= activePlayerCount;
  }

  return (
    allMatched &&
    next === lastRaiser
  );
}

function resetBettingRound() {

  const updatedPlayers = [...players];
  for (const player of updatedPlayers) {
    player.bet = 0;
  }

  setPlayers(updatedPlayers);

  setCurrentBet(0);
  setActionCount(0);
  setLastRaiser(null);

}

function advanceStreet() {
  resetBettingRound();
  setLastRaiser(null);
  setCurrentPlayer(
    getFirstPostFlopPlayer()
  );

  if (street === "PREFLOP") {
    setBoardCards(3);
    setStreet("FLOP");
  } else if (street === "FLOP") {
    setBoardCards(4)
    setStreet("TURN");
  } else if (street === "TURN") {
    setBoardCards(5)
    setStreet("RIVER");
  } else if (street === "RIVER") {
    setStreet("SHOWDOWN");
  }
  
}

function rotateDealer(updatedPlayers) {

  let dealerIndex = 0;

  for (let i = 0; i < updatedPlayers.length; i++) {
    if (updatedPlayers[i].dealer) {
      dealerIndex = i;
      break;
    }
  }

  updatedPlayers[dealerIndex].dealer = false;

  const newDealer =
    (dealerIndex + 1) % updatedPlayers.length;

  updatedPlayers[newDealer].dealer = true;
}

function rotateBlinds(updatedPlayers) {

  for (const player of updatedPlayers) {
    player.sb = false;
    player.bb = false;
  }

  let dealerIndex = 0;

  for (let i = 0; i < updatedPlayers.length; i++) {
    if (updatedPlayers[i].dealer) {
      dealerIndex = i;
      break;
    }
  }

  const sbIndex =
    (dealerIndex + 1) % updatedPlayers.length;

  const bbIndex =
    (dealerIndex + 2) % updatedPlayers.length;

  updatedPlayers[sbIndex].sb = true;
  updatedPlayers[bbIndex].bb = true;
}

function getFirstPlayer(updatedPlayers) {

  let bbIndex = 0;

  for (let i = 0; i < updatedPlayers.length; i++) {
    if (updatedPlayers[i].bb) {
      bbIndex = i;
      break;
    }
  }

  return (bbIndex + 1) % updatedPlayers.length;
}

function newHand() {
  playClick();

  const updatedPlayers = [...players];
  rotateDealer(updatedPlayers);
  rotateBlinds(updatedPlayers);
  setCurrentPlayer(getFirstPlayer(updatedPlayers));

  setCurrentBet(20);
  setWinner(null);
  setStreet("PREFLOP");
  setActionLog([]);
  setActionCount(0);
  setBoardCards(0);


for (const player of updatedPlayers) {
  player.bet = 0;
  player.folded = false;
}

let sbIndex = -1;
let bbIndex = -1;

for (let i = 0; i < updatedPlayers.length; i++) {
  if (updatedPlayers[i].sb) sbIndex = i;
  if (updatedPlayers[i].bb) bbIndex = i;
}

if (sbIndex !== -1) {
  updatedPlayers[sbIndex].chips -= 10;
  updatedPlayers[sbIndex].bet = 10;
}

if (bbIndex !== -1) {
  updatedPlayers[bbIndex].chips -= 20;
  updatedPlayers[bbIndex].bet = 20;
}

setPot(30);
setLastRaiser(bbIndex);
setPlayers(updatedPlayers);
setHandComplete(false);
}

function addAction(text) {
  console.log("ADDING: ",text);

  setActionLog((prev) => [
    text,
    ...prev
  ].slice(0, 5));
}

function getFirstPostFlopPlayer() {

  let dealerIndex = 0;

  for (let i = 0; i < players.length; i++) {
    if (players[i].dealer) {
      dealerIndex = i;
      break;
    }
  }

  let next =
    (dealerIndex + 1) % players.length;

  while (players[next].folded) {
    next = (next + 1) % players.length;
  }

  return next;
}

function awardPot() {
  playClick();

  if (selectedWinner === null) {
    return;
  }

  if (players[selectedWinner].folded) {
    return;
  }

  if (handComplete) {
    return;
  }

  const updatedPlayers = [...players];

  updatedPlayers[selectedWinner].chips += pot;

  setPlayers(updatedPlayers);

  setPot(0);

  setSelectedWinner(null);

  setWinner(updatedPlayers[selectedWinner].name);

  setHandComplete(true);
}

function getSeatPositions(playerCount) {
  const positions = [];

  const centerX = 50;
  const centerY = 50;

  const radiusX = 35;
  const radiusY = 35;

  for (let i = 0; i < playerCount; i++) {
    const angle =
      (2 * Math.PI * i) / playerCount -
      Math.PI / 2;

    positions.push({
      x: `${centerX + radiusX * Math.cos(angle)}%`,
      y: `${centerY + radiusY * Math.sin(angle)}%`,
    });
  }

  return positions;
}

function createPlayers(playerCount, playerNames) {
  const positions =
    getSeatPositions(playerCount);

  return positions.map(
    (position, index) => ({
      name:
  playerNames[index] ||
  `Player ${index + 1}`,
      chips: 1000,
      bet: 0,
      folded: false,

      dealer: index === 0,
      sb: index === (1 % playerCount),
      bb: index === (2 % playerCount),

      x: position.x,
      y: position.y,
    })
  );
}

function startGame() {

  const newPlayers =
    createPlayers(playerCount, playerNames);

  let sbIndex = -1;
  let bbIndex = -1;

  for (let i = 0; i < newPlayers.length; i++) {
    if (newPlayers[i].sb) sbIndex = i;
    if (newPlayers[i].bb) bbIndex = i;
  }

  if (sbIndex !== -1) {
    newPlayers[sbIndex].chips -= 10;
    newPlayers[sbIndex].bet = 10;
  }

  if (bbIndex !== -1) {
    newPlayers[bbIndex].chips -= 20;
    newPlayers[bbIndex].bet = 20;
  }

  setPlayers(newPlayers);

  setPot(30);

  setCurrentBet(20);

  setLastRaiser(bbIndex);

  setCurrentPlayer(
    getFirstPlayer(newPlayers)
  );

  setGameStarted(true);
}

if (!gameStarted){
  return (
    <div
      style={{
        minHeight: "100vh",
        background: "#111",
        color: "white",
        padding: "20px",
      }}
    >
      <h1 style={{ textAlign: "center" }}>
        Poker Companion
      </h1>

      <select
  value={playerCount}
  onChange={(e) => {
    const count =
      Number(e.target.value);

    setPlayerCount(count);

    setPlayers(
      createPlayers(count, playerNames)
    );
  }}
>
  {[2,3,4,5,6,7,8,9,10].map(
    count => (
      <option
        key={count}
        value={count}
      >
        {count} Players
      </option>
    )
  )}
</select>

{Array.from(
  { length: playerCount },
  (_, index) => (
    <div key={index}>
      <input
        type="text"
        placeholder={`Player ${index + 1}`}
        value={playerNames[index]}
        onChange={(e) => {

          const updated =
            [...playerNames];

          updated[index] =
            e.target.value;

          setPlayerNames(updated);
        }}
      />
    </div>
  )
)}

<button
  onClick={startGame}
>
  Start Game
</button>
  </div>
  );
}

  return (
    <>
      <h2>
        Street: {street}
      </h2>

      <h2>
        Turn: {players[currentPlayer].name}
      </h2>

      <button
      onClick={() => {if (bettingRoundComplete(players)) {advanceStreet();}}}
      >
      End Betting Round
      </button>

{winner && (
  <div
    style={{
      fontSize: "48px",
      color: "gold",
      textAlign: "center",
      fontWeight: "bold",
      marginTop: "20px",
    }}
  >
    🏆 {winner} WINS! 🏆
  </div>
)}

      <div
        style={{
          border: "2px solid green",
          borderRadius: "999px",
          width: "500px",
          height: "500px",
          margin: "40px auto",
          position: "relative",
        }}
      >
        {players.map((player, index) => (
          <div
            key={index}
            onClick={() => {
              if (
                street === "SHOWDOWN" &&
                !player.folded
              ) {
                setSelectedWinner(index);
              }
            }}
            style={{
              left: player.x,
              top: player.y,
              transform: "translate(-50%, -50%)",
              position: "absolute",
              background:
              player.folded
                ? "#7f1d1d"
                : index === currentPlayer
                ? "#facc15"
                : "#444",
                border:
  index === currentPlayer
    ? "4px solid white"
    : "none",

boxShadow:
  index === currentPlayer
    ? "0 0 20px gold"
    : "none",
              borderRadius: "50%",
              width: "95px",
              height: "95px",
              display: "flex",
              alignItems: "center",
              justifyContent: "center",
              textAlign: "center",
              fontSize: "14px",
              border:
  selectedWinner === index
    ? "4px solid lime"
    : "none",

cursor:
  street === "SHOWDOWN"
    ? "pointer"
    : "default",
            }}
            
          >
            <div>
              <div>
                {player.name}
                {player.folded && " (Folded)"}
              </div>

              <div>{player.chips}</div>

              <div>Bet: {player.bet}</div>

              {player.dealer && (
                <div
                  style={{
                    position: "absolute",
                    top: "-12px",
                    right: "-12px",
                    background: "gold",
                    color: "black",
                    borderRadius: "50%",
                    width: "24px",
                    height: "24px",
                    display: "flex",
                    alignItems: "center",
                    justifyContent: "center",
                    fontWeight: "bold",
                  }}
                >
                  D 
                 </div>
                )}
                {player.sb && (
                  <div
                    style={{
                      position: "absolute",
                      top: "-12px",
                      left: "-12px",
                      background: "dodgerblue",
                      color: "white",
                      borderRadius: "50%",
                      width: "24px",
                      height: "24px",
                      display: "flex",
                      alignItems: "center",
                      justifyContent: "center",
                      fontWeight: "bold",
                      fontSize: "10px",
                    }}
                  >
                    SB
                  </div>
                )}

                {player.bb && (
                  <div
                    style={{
                      position: "absolute",
                      bottom: "-12px",
                      left: "-12px",
                      background: "crimson",
                      color: "white",
                      borderRadius: "50%",
                      width: "24px",
                      height: "24px",
                      display: "flex",
                      alignItems: "center",
                      justifyContent: "center",
                      fontWeight: "bold",
                      fontSize: "10px",
                    }}
                  >
                    BB
                  </div>
                )}
              </div>
            </div>
  ))}
  <div
  style={{
    position: "absolute",
    left: "50%",
    top: "50%",
    transform: "translate(-50%, -50%)",
    fontSize: "28px",
    fontWeight: "bold",
  }}
>
<div
  style={{
    display: "flex",
    justifyContent: "center",
    gap: "8px",
    marginBottom: "10px",
  }}
>
  {Array.from(
    { length: boardCards },
    (_, index) => (
      <div
        key={index}
        style={{
          width: "40px",
          height: "60px",
          background: "#1e40af",
          border: "2px solid white",
          borderRadius: "6px",
        }}
      />
    )
  )}
</div>
  Pot: {pot}

  <div>
    Current Bet: {currentBet}
  </div>

  <div>
    Raise Amount: {raiseAmount}
  </div>
</div>
  </div>
      <div
        style={{
          display: "flex",
          gap: "12px",
          justifyContent: "center",
          flexWrap: "wrap",
          marginTop: "20px"
        }}
      >
        <button
            onClick={foldPlayer}
            style={{
              padding: "12px 20px",
              fontSize: "18px",
              borderRadius: "12px",
              border: "none",
              cursor: "pointer",
              background: "#dc2626",
              color: "white",
              fontWeight: "bold",
            }}
        >
          Fold
        </button>
        <button
          onClick={checkAction}
          style={{
            padding: "12px 20px",
            fontSize: "18px",
            borderRadius: "12px",
            border: "none",
            cursor: "pointer",
            background: "#2563eb",
            color: "white",
            fontWeight: "bold",
          }}
        >
          Check
        </button>
        <button
          onClick={callAction}
          style={{
            padding: "12px 20px",
            fontSize: "18px",
            borderRadius: "12px",
            border: "none",
            cursor: "pointer",
            background: "#16a34a",
            color: "white",
            fontWeight: "bold",
          }}
        >
          Call
        </button>
        <button
          onClick={raiseAction}
          style={{
            padding: "12px 20px",
            fontSize: "18px",
            borderRadius: "12px",
            border: "none",
            cursor: "pointer",
            background: "#facc15",
            color: "black",
            fontWeight: "bold",
          }}
        >
          Raise
        </button>
        <button
          onClick={() => setRaiseAmount(raiseAmount + 20)}
          style={{
            background: "#444",
            color: "white",
            border: "none",
            borderRadius: "8px",
            padding: "10px",
            cursor: "pointer",
          }}
        >
          +20
        </button>
        <button
          onClick={() =>
            setRaiseAmount(Math.max(20, raiseAmount - 20))
          }
          style={{
            background: "#444",
            color: "white",
            border: "none",
            borderRadius: "8px",
            padding: "10px",
            cursor: "pointer",
          }}
        >
          -20
        </button>
        <button
style={{
  padding: "12px 20px",
  fontSize: "18px",
  borderRadius: "12px",
  border: "none",
  cursor: "pointer",
  background: "#9333ea",
  color: "white",
  fontWeight: "bold",
}}
        >
          All In
        </button>
        {street === "SHOWDOWN" && (
  <button onClick={awardPot}>
    Award Pot
  </button>
)}
{handComplete && (
  <button onClick={newHand}>
    Next Hand
  </button>
)}
<button
  onClick={advanceStreet}
  style={{
    background: "#525252",
    color: "white",
    padding: "12px 20px",
    fontSize: "18px",
    borderRadius: "12px",
    border: "none",
    cursor: "pointer",
  }}
>
  Advance Street
</button>

<div
style={{
  background: "#1f2937",
  padding: "15px",
  borderRadius: "12px",
  minWidth: "250px",
  minHeight: "150px",
  color: "white",
}}
>
<h3
  style={{
    marginTop: 0,
    color: "#facc15",
  }}
>
  Recent Actions
</h3>

{actionLog.map((entry, i) => (
  <div
    key={i}
    style={{
      marginBottom: "6px",
    }}
  >
    {entry}
  </div>
))}
</div>
          <div>
          Last Raiser:
          {lastRaiser !== null
              ? players[lastRaiser].name
              : "None"}
        </div>
      </div>
    </>
  );
}

export default App;
